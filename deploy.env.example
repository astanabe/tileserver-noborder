# Per-deployment configuration for tileserver-noborder.
#
# Procedure:
#   1. cp deploy.env.example deploy.env
#   2. Edit deploy.env with your values
#   3. Run scripts/render-configs.sh
#      → produces $REPO/staging/{etc,data,web}/ with your values substituted
#   4. Install from $REPO/staging/... per tileserver-noborder.md §9.x
#
# deploy.env is gitignored. Do not commit it.

# ---------------------------------------------------------------------------
# REQUIRED — set these.
# ---------------------------------------------------------------------------

# OS user that owns the build dir, runs tileserver-gl, runs nginx workers,
# and is named in /etc/sudoers.d/tileserver-rebuild. Must already exist.
# Defaults to the current login user (the repo and the server are assumed to
# run as the same user); set an explicit name only if they differ. e.g. foobar
USER_NAME="${USER_NAME:-$(id -un)}"

# Public hostname for the tile server. Must have A/AAAA records pointing
# at this host before running certbot. Used as nginx server_name, in the
# nginx site config filename, in Let's Encrypt cert paths, in demo.html, etc.
DOMAIN=tile.hogehoge.com

# Email for Let's Encrypt expiration notifications (passed to certbot -m).
# Used in the doc's certbot example only; not substituted into any tracked file.
ADMIN_EMAIL=admin@hogehoge.com

# ---------------------------------------------------------------------------
# OPTIONAL — defaults are derived from the values above. Override only if
# you intentionally lay things out differently.
# ---------------------------------------------------------------------------

# Planetiler build/tmp directory. Needs ~300 GB free for a full-planet build.
# Often kept on a separate large NVMe (/work) so the OS partition stays small.
BUILD_ROOT=/work/${USER_NAME}/planetiler

# Java heap for Planetiler (applied as both -Xms and -Xmx). Default 32736m
# (= 32 GiB - 32 MiB) sits just under the JVM's CompressedOops cutoff so
# 32-bit object references stay enabled (~10-30% heap + CPU cache savings).
# Works well on any host with >= 40 GB RAM when using --storage=mmap. Only
# raise this when switching to --storage=ram on a 128+ GB machine.
# See tileserver-noborder.md §8 for the sizing table.
PLANETILER_XMX=32736m

# tileserver-gl npm project root (contains node_modules/, data/, etc.)
TILESERVER_HOME=/home/${USER_NAME}/tileserver-gl

# tileserver-gl data directory (config.json, mbtiles, styles/, sprites/, fonts/)
TILESERVER_DATA=${TILESERVER_HOME}/data

# nginx static-file root for this domain (serves /demo.html and ACME challenge)
HTTP_ROOT=/home/${USER_NAME}/http/${DOMAIN}

# Path where this repository is checked out.
# scripts/rebuild.sh derives this from its own location at runtime, so this
# value mainly affects the systemd unit's ExecStart.
REPO=/home/${USER_NAME}/tileserver-noborder
